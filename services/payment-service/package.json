{
  "name": "@services/payment-service",
  "private": true,
  "version": "0.1.0",
  "description": "Payment Service (Express + TypeScript + Stripe).",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "stripe:listen": "stripe listen --forward-to localhost:4005/webhooks/stripe"
  },
  "dependencies": {
    "amqplib": "^0.10.3",
    "axios": "^1.7.7",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "helmet": "^7.2.0",
    "pino": "^9.6.0",
    "pino-http": "^10.5.0",
    "stripe": "^14.9.0",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.23",
    "@types/node": "^20.19.10",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
