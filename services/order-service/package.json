{
  "name": "@services/order-service",
  "private": true,
  "version": "0.1.0",
  "description": "Order Service (Express + TypeScript + PostgreSQL + Prisma).",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "amqplib": "^0.10.3",
    "axios": "^1.7.7",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "helmet": "^7.2.0",
    "pino": "^9.6.0",
    "pino-http": "^10.5.0",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.18",
    "@types/amqplib": "^0.10.5",
    "@types/express": "^4.17.23",
    "@types/node": "^20.19.10",
    "prisma": "^5.20.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
