{
  "name": "@services/api-gateway",
  "private": true,
  "version": "0.1.0",
  "description": "API Gateway for microservices (Express + http-proxy-middleware).",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "http-proxy-middleware": "^3.0.5",
    "pino": "^9.6.0",
    "pino-http": "^10.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.23",
    "@types/node": "^20.19.10",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}

